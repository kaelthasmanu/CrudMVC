@model CrudMVC.Models.Contact

@{
    ViewData["Title"] = "Delete Contact";
}

<!DOCTYPE html>

<html>
<head>
    <title>Delete Contact</title>
</head>
<body>
<div>
    <h1 class="text-center">Delete Contact</h1>
    <h3 class="text-center">You are sure delete this contact?</h3>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">ID</dt>
        <dd class="col-sm-10">@Model.Id</dd>

        <dt class="col-sm-2">Name</dt>
        <dd class="col-sm-10">@Model.Name</dd>

        <dt class="col-sm-2">Email</dt>
        <dd class="col-sm-10">@Model.Email</dd>

        <dt class="col-sm-2">Phone</dt>
        <dd class="col-sm-10">@Model.Phone</dd>

        <dt class="col-sm-2">Direction</dt>
        <dd class="col-sm-10">@Model.Direction</dd>
        
        <form asp-action="Delete" method="post">
            <input type="hidden" asp-for="Id"/>
            <button type="submit" class="btn btn-danger">Delete</button>
            <a asp-action="Index" class="btn btn-secondary">Back to List</a>
        </form>
        
    </dl>
</div>
</body>
</html>